        </mxCell>
        <mxCell id="de8" edge="1" parent="1" source="d_ext_eval" style="endArrow=open;endFill=0;endSize=10;strokeWidth=1.5;dashed=1;strokeColor=#b85450;fontSize=10;fontStyle=2;labelBackgroundColor=#FFFFFF;" target="d_memhost" value="uses">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
