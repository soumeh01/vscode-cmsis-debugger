          <mxGeometry height="35" width="500" x="540" y="15" as="geometry" />
        </mxCell>
        <mxCell id="s1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=11;" value="&lt;b&gt;1. Debug Session Connects&lt;/b&gt;&lt;br&gt;GDBTargetDebugTracker fires &lt;b&gt;onConnected&lt;/b&gt;" vertex="1">
          <mxGeometry height="60" width="380" x="580" y="70" as="geometry" />
        </mxCell>
        <mxCell id="s2" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=11;" value="&lt;b&gt;2. ComponentViewer.handleOnConnected()&lt;/b&gt;&lt;br&gt;Sets _activeSession&lt;br&gt;Calls loadCbuildRunInstances()" vertex="1">
          <mxGeometry height="75" width="380" x="580" y="170" as="geometry" />
        </mxCell>
        <mxCell id="s3" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=11;" value="&lt;b&gt;3. readScvdFiles()&lt;/b&gt;&lt;br&gt;session.getCbuildRun() -&gt; cbuildRunReader&lt;br&gt;cbuildRunReader.getScvdFilePaths(pname)&lt;br&gt;For each SCVD path -&gt; new ComponentViewerInstance" vertex="1">
          <mxGeometry height="85" width="420" x="580" y="285" as="geometry" />
        </mxCell>
        <mxCell id="s4_box" parent="1" style="rounded=1;whiteSpace=wrap;html=1;dashed=1;strokeColor=#82B366;fillColor=#F0FFF0;" value="" vertex="1">
          <mxGeometry height="940" width="1720" x="40" y="420" as="geometry" />
        </mxCell>
        <mxCell id="s4_title" parent="1" style="text;html=1;fontSize=14;align=left;fontStyle=1;" value="&lt;b&gt;4. ComponentViewerInstance.readModel(scvdFile, session, tracker)&lt;/b&gt;" vertex="1">
          <mxGeometry height="25" width="600" x="440" y="430" as="geometry" />
        </mxCell>
        <mxCell id="s4a" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAEEF3;strokeColor=#5B9BD5;fontSize=10;" value="&lt;b&gt;4a. Read SCVD File &amp;amp; Parse XML&lt;/b&gt;&lt;br&gt;&lt;hr&gt;vscode.workspace.fs.readFile(scvdURI)&lt;br&gt;injectLineNumbers(xml) -- adds __line attrs&lt;br&gt;xml2js.parseStringPromise(xml, opts)&lt;br&gt;-&gt; JSON model (explicitChildren, preserveOrder)" vertex="1">
          <mxGeometry height="130" width="340" x="80" y="475" as="geometry" />
        </mxCell>
        <mxCell id="s4b" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1D5E7;strokeColor=#9673A6;fontSize=10;" value="&lt;b&gt;4b. Build SCVD Object Model&lt;/b&gt;&lt;br&gt;&lt;hr&gt;new ScvdComponentViewer()&lt;br&gt;model.readXml(json)&lt;br&gt;recursively creates:&lt;br&gt;  ScvdObjects -&gt; ScvdObject&lt;br&gt;    -&gt; ScvdRead, ScvdReadList, ScvdVar,&lt;br&gt;       ScvdCalc, ScvdList, ScvdListOut,&lt;br&gt;       ScvdOut, ScvdItem, ScvdPrint, ScvdBreak&lt;br&gt;  ScvdTypedefs -&gt; ScvdTypedef -&gt; ScvdMember&lt;br&gt;  ScvdBreaks (collected from all nesting levels)" vertex="1">
          <mxGeometry height="195" width="340" x="80" y="650" as="geometry" />
        </mxCell>
        <mxCell id="s4c" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#CCE5FF;strokeColor=#0050EF;fontSize=10;" value="&lt;b&gt;4c. Init Evaluation Context&lt;/b&gt;&lt;br&gt;&lt;hr&gt;new ScvdEvalContext(model)&lt;br&gt;creates:&lt;br&gt;  MemoryHost (local byte store)&lt;br&gt;  RegisterHost (per-cycle register cache)&lt;br&gt;  ScvdDebugTarget (-&gt; GDB access)&lt;br&gt;  ScvdEvalInterface (ModelHost + DataAccessHost)&lt;br&gt;  ScvdExpressionParser (Parser + Optimizer)&lt;br&gt;  Evaluator (AST evaluator, IntegerModel)&lt;br&gt;  ExecutionCancellation (10s timeout)&lt;br&gt;&lt;br&gt;evalContext.init(session, tracker)&lt;br&gt;  -&gt; debugTarget.init(session, tracker)&lt;br&gt;  -&gt; configureIntegerModel()" vertex="1">
          <mxGeometry height="235" width="340" x="520" y="475" as="geometry" />
        </mxCell>
        <mxCell id="s4d" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1D5E7;strokeColor=#9673A6;fontSize=10;" value="&lt;b&gt;4d. Configure &amp;amp; Validate Model&lt;/b&gt;&lt;br&gt;&lt;hr&gt;model.setExecutionContextAll(execCtx)&lt;br&gt;  -&gt; every ScvdNode gets ExecutionContext ref&lt;br&gt;model.configureAll()&lt;br&gt;  -&gt; configure() each node recursively&lt;br&gt;  -&gt; clearSymbolCachesRecursive()&lt;br&gt;model.validateAll(true)&lt;br&gt;  -&gt; validate() each node recursively" vertex="1">
          <mxGeometry height="160" width="340" x="520" y="755" as="geometry" />
        </mxCell>
        <mxCell id="s4e" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1D5E7;strokeColor=#9673A6;fontSize=10;" value="&lt;b&gt;4e. Resolve Types &amp;amp; Link References&lt;/b&gt;&lt;br&gt;&lt;hr&gt;new Resolver(model)&lt;br&gt;resolver.resolve()&lt;br&gt;  -&gt; createTypesCache()&lt;br&gt;     ScvdTypesCache.createCache()&lt;br&gt;  -&gt; resolveTypes()&lt;br&gt;     Walk all nodes recursively:&lt;br&gt;     node.resolveAndLink(cb)&lt;br&gt;       cb resolves: localType, localMember,&lt;br&gt;       targetType references&lt;br&gt;&lt;br&gt;model.calculateTypedefs()&lt;br&gt;  -&gt; compute sizes, offsets from GDB" vertex="1">
          <mxGeometry height="220" width="330" x="960" y="475" as="geometry" />
        </mxCell>
        <mxCell id="s4f" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8CECC;strokeColor=#B85450;fontSize=10;" value="&lt;b&gt;4f. Build Statement Tree&lt;/b&gt;&lt;br&gt;&lt;hr&gt;new StatementEngine(model, execCtx)&lt;br&gt;statementEngine.initialize()&lt;br&gt;addChildrenFromScvd(object, parent)&lt;br&gt;  -&gt; maps ScvdNode types to Statement types:&lt;br&gt;    ScvdObject  -&gt; StatementObject&lt;br&gt;    ScvdRead    -&gt; StatementRead&lt;br&gt;    ScvdReadList-&gt; StatementReadList&lt;br&gt;    ScvdVar     -&gt; StatementVar&lt;br&gt;    ScvdCalc    -&gt; StatementCalc&lt;br&gt;    ScvdList    -&gt; StatementList&lt;br&gt;    ScvdListOut -&gt; StatementListOut&lt;br&gt;    ScvdOut     -&gt; StatementOut&lt;br&gt;    ScvdItem    -&gt; StatementItem&lt;br&gt;    ScvdPrint   -&gt; StatementPrint&lt;br&gt;sortChildren() (by line number, stable)&lt;br&gt;insertBreakAtLine() for each ScvdBreak&lt;br&gt;sortChildren() again" vertex="1">
          <mxGeometry height="310" width="330" x="960" y="740" as="geometry" />
        </mxCell>
        <mxCell id="s4g" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=10;" value="&lt;b&gt;4g. Create GUI Tree Root&lt;/b&gt;&lt;br&gt;&lt;hr&gt;new ScvdGuiTree(undefined)&lt;br&gt;guiTree.setId(instanceKey)&lt;br&gt;guiTree.setGuiName(&#39;root&#39;)" vertex="1">
          <mxGeometry height="100" width="280" x="1390" y="475" as="geometry" />
        </mxCell>
        <mxCell id="s5" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=11;" value="&lt;b&gt;5. Store Instances&lt;/b&gt;&lt;br&gt;_instances.push({ instance, lockState: false, sessionId, dirtyWhileLocked: false })" vertex="1">
          <mxGeometry height="70" width="340" x="80" y="890" as="geometry" />
        </mxCell>
        <mxCell id="cache_box" parent="1" style="rounded=1;whiteSpace=wrap;html=1;dashed=1;strokeColor=#AE4132;fillColor=#FFF5EE;" value="" vertex="1">
