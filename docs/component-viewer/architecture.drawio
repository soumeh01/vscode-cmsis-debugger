        <mxCell id="ph1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8CECC;strokeColor=#B85450;fontSize=10;" value="&lt;b&gt;Phase 1: Reset Caches&lt;/b&gt;&lt;br&gt;&lt;hr&gt;cancellation.reset(10_000ms)&lt;br&gt;memoryHost.clearNonConst()&lt;br&gt;evalHost.resetEvalCaches()&lt;br&gt;evalHost.resetPrintfCache()&lt;br&gt;evaluator.resetEvalCaches()" vertex="1">
          <mxGeometry height="130" width="270" x="70" y="845" as="geometry" />
        </mxCell>
        <mxCell id="ph2" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8CECC;strokeColor=#B85450;fontSize=10;" value="&lt;b&gt;Phase 2: Begin Update Cycle&lt;/b&gt;&lt;br&gt;&lt;hr&gt;debugTarget.beginUpdateCycle()&lt;br&gt;  -&gt; targetReadStats.reset()&lt;br&gt;  -&gt; targetReadCache.beginUpdateCycle()&lt;br&gt;    merge requestedRanges (from prev cycle)&lt;br&gt;    prefetch: readMemoryFromTarget&lt;br&gt;      for each merged range&lt;br&gt;    populate TargetReadCache segments&lt;br&gt;  -&gt; resetReadTimingStats()" vertex="1">
          <mxGeometry height="155" width="330" x="400" y="845" as="geometry" />
        </mxCell>
        <mxCell id="ph3" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8CECC;strokeColor=#B85450;fontSize=10;" value="&lt;b&gt;Phase 3: Execute Statement Tree&lt;/b&gt;&lt;br&gt;&lt;hr&gt;statementTree.executeStatement(execCtx, guiTree)&lt;br&gt;Depth-first walk:" vertex="1">
          <mxGeometry height="70" width="350" x="790" y="845" as="geometry" />
        </mxCell>
        <mxCell id="sb_flow" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8CECC;strokeColor=#B85450;fontSize=10;" value="&lt;b&gt;StatementBase.executeStatement()&lt;/b&gt;&lt;br&gt;&lt;hr&gt;1. shouldExecute()&lt;br&gt;   mustRead check (const skip)&lt;br&gt;   getConditionResult()&lt;br&gt;     -&gt; Evaluator.evaluate(condExpr)&lt;br&gt;2. onExecute()  (overridden per type)&lt;br&gt;3. for child -&gt; child.executeStatement()" vertex="1">
          <mxGeometry height="145" width="320" x="70" y="1060" as="geometry" />
