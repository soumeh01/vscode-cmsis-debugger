  <diagram id="page2" name="2 - Init / Read / Build Model Path">
    <mxGraphModel dx="2298" dy="1074" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1800" pageHeight="1400" math="0" shadow="0">
      <root>
