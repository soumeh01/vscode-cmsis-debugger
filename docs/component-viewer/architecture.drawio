        <mxCell id="st_read" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE6CC;strokeColor=#AE4132;fontSize=10;" value="&lt;b&gt;StatementRead.onExecute()&lt;/b&gt;&lt;br&gt;&lt;hr&gt;1. resolveRead():&lt;br&gt;   scvdRead.name / getTargetSize / getArraySize&lt;br&gt;   debugTarget.findSymbolAddress(symbol)&lt;br&gt;   scvdRead.offset.getValue()&lt;br&gt;   -&gt; baseAddress + readBytes&lt;br&gt;2. debugTarget.&lt;b&gt;readMemory&lt;/b&gt;(addr, size)&lt;br&gt;3. memoryHost.&lt;b&gt;setVariable&lt;/b&gt;(name, data)&lt;br&gt;4. If isConst -&gt; mustRead = false (skip next)" vertex="1">
          <mxGeometry height="175" width="340" x="460" y="1060" as="geometry" />
        </mxCell>
        <mxCell id="st_readlist" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE6CC;strokeColor=#AE4132;fontSize=10;" value="&lt;b&gt;StatementReadList.onExecute()&lt;/b&gt;&lt;br&gt;&lt;hr&gt;1. resolveReadList():&lt;br&gt;   name / targetSize / symbolAddr / offset&lt;br&gt;   isPointerArray (based=1)&lt;br&gt;   maxArraySize from getNumArrayElements&lt;br&gt;2. handle init (clear if init=1)&lt;br&gt;3. resolve &#39;next&#39; member (linked list)&lt;br&gt;4. Loop (max count or until NULL):&lt;br&gt;   cancellation.checkDeadline()&lt;br&gt;   debugTarget.&lt;b&gt;readMemory&lt;/b&gt;(addr, size)&lt;br&gt;   memoryHost.&lt;b&gt;setVariable&lt;/b&gt; (append)&lt;br&gt;   follow next pointer or advance index" vertex="1">
          <mxGeometry height="220" width="340" x="460" y="1290" as="geometry" />
        </mxCell>
        <mxCell id="st_var" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#CCE5FF;strokeColor=#0050EF;fontSize=10;" value="&lt;b&gt;StatementVar.onExecute()&lt;/b&gt;&lt;br&gt;&lt;hr&gt;name / getTargetSize / getArraySize&lt;br&gt;getValue() -&gt; initial value&lt;br&gt;memoryHost.&lt;b&gt;setVariable&lt;/b&gt;(name,&lt;br&gt;  size, initValue, appendOffset)" vertex="1">
